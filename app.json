{
  "expo": {
    "name": "Toss",
    "slug": "Toss",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Heads.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "app.stridehub.toss",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/Heads.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/Heads.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/Heads.png",
          "backgroundColor": "#000000",
          "imageWidth": 240,
          "resizeMode": "contain"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "344dbf0f-26bc-4847-8407-2f11dbd282d6"
      }
    },
    "owner": "dapphari007"
  }
}
